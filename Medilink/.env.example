# ============================================================================
# MediLink — environment variables (copy to .env / per-workspace .env.local).
# Keys mirror the reused HAMS backend. NEVER commit real values.
# Legend:  PUBLIC = safe for browser/mobile (NEXT_PUBLIC_/EXPO_PUBLIC_);
#          SECRET = backend-only — must never reach frontend or mobile bundles.
# ============================================================================

# ---- Supabase (existing HAMS project — reused) ----
NEXT_PUBLIC_SUPABASE_URL=              # PUBLIC
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # PUBLIC
SUPABASE_SERVICE_ROLE_KEY=             # SECRET (backend only)
# Mobile mirrors of the public values:
EXPO_PUBLIC_SUPABASE_URL=              # PUBLIC
EXPO_PUBLIC_SUPABASE_ANON_KEY=         # PUBLIC

# ---- App / service URLs ----
NEXT_PUBLIC_APP_URL=                   # PUBLIC (frontend origin)
NEXT_PUBLIC_BACKEND_URL=               # PUBLIC (web → backend API origin)
EXPO_PUBLIC_BACKEND_URL=               # PUBLIC (mobile → backend API origin)

# ---- Payments — Thawani (PRIMARY) ----
THAWANI_BASE_URL=                      # SECRET
THAWANI_API=                           # SECRET
THAWANI_API_KEY=                       # SECRET
THAWANI_SECRET_KEY=                    # SECRET
THAWANI_PUBLISHABLE_KEY=               # PUBLIC

# ---- Payments — Stripe (secondary/optional) ----
STRIPE_SECRET_KEY=                     # SECRET
STRIPE_WEBHOOK_SECRET=                 # SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # PUBLIC

# ---- Google (OAuth + Calendar) ----
GOOGLE_CLIENT_ID=                      # SECRET
GOOGLE_CLIENT_SECRET=                  # SECRET
GOOGLE_REDIRECT_URI=                   # SECRET

# ---- AI (Me Assistant / Insights) ----
GEMINI_API_KEY=                        # SECRET
GROQ_API_KEY=                          # SECRET
MOCK_AI=false                          # backend flag — stub AI when true

# ---- Email (Resend / nodemailer) ----
EMAIL_USER=                            # SECRET
EMAIL_PASS=                            # SECRET
EMAIL_FROM=                            # SECRET

# ---- Misc ----
INVITE_SECRET=                         # SECRET

# ---- Internal API docs (Scalar / OpenAPI) ----
# Enables GET /api/docs and GET /api/openapi.json. Off by default.
# In production these stay 404 unless the caller is an authenticated internal admin.
ENABLE_API_DOCS=false                  # backend flag — set "true" in dev/staging
