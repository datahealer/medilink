{
  "$comment": "Shared compiler options for all MediLink workspaces. Each workspace extends this.",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "paths": {
      "@medilink/shared": ["./shared/src/index.ts"],
      "@medilink/shared/*": ["./shared/src/*"]
    }
  }
}
