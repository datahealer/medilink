# App environment
EXPO_PUBLIC_APP_ENV=development

# Data source: mock | staging | production
#   mock        → typed in-memory data, NO backend calls (UI-first; the dev default)
#   staging     → real HAMS/Supabase against staging
#   production  → real HAMS/Supabase against production
# In mock mode the SUPABASE/API vars below are optional (safe fallbacks are used).
EXPO_PUBLIC_DATA_MODE=mock

# Backend API (HAMS Next.js) — used for privileged ops such as Thawani payment checkout.
# The value MUST be a host the device/emulator can actually reach:
#   • Physical phone : your laptop's LAN IP, e.g. http://192.168.1.20:3000 (NOT localhost),
#                      with the phone on the SAME Wi-Fi and the laptop firewall allowing TCP 3000.
#   • Android emulator: http://10.0.2.2:3000  (10.0.2.2 = the host machine; "localhost" is auto-
#                      rewritten to this on Android by the app's apiFetch helper).
#   • iOS simulator  : http://localhost:3000   (the simulator shares the host network).
#   • Staging/prod   : the deployed HTTPS URL, e.g. https://staging.medilink.om
# IMPORTANT: start HAMS bound to all interfaces so the device can connect:  next dev -H 0.0.0.0
EXPO_PUBLIC_API_URL=http://YOUR_LAPTOP_IP:3000

# Supabase public client config — add later if mobile connects directly to Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth public client IDs — add later when OAuth is configured
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Expo project ID — needed later for EAS / push notifications
EXPO_PUBLIC_EXPO_PROJECT_ID=
