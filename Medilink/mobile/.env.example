# App environment
EXPO_PUBLIC_APP_ENV=development

# Data source: mock | staging | production
#   mock        → typed in-memory data, NO backend calls (UI-first; the dev default)
#   staging     → real HAMS/Supabase against staging
#   production  → real HAMS/Supabase against production
# In mock mode the SUPABASE/API vars below are optional (safe fallbacks are used).
EXPO_PUBLIC_DATA_MODE=mock

# Backend API — add when HAMS/MediLink API is ready
EXPO_PUBLIC_API_URL=http://YOUR_LAPTOP_IP:3000

# Supabase public client config — add later if mobile connects directly to Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth public client IDs — add later when OAuth is configured
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Expo project ID — needed later for EAS / push notifications
EXPO_PUBLIC_EXPO_PROJECT_ID=
