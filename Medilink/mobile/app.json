{
  "expo": {
    "name": "MediLink",
    "slug": "medilink",
    "scheme": "medilink",
    "version": "0.1.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medilink.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to securely unlock your saved session."
      }
    },
    "android": {
      "package": "com.medilink.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      ["expo-notifications", { "color": "#2E1A47" }],
      ["expo-image-picker", { "photosPermission": "MediLink uses your photos to set a profile picture." }]
    ],
    "extra": {
      "eas": { "projectId": "" }
    }
  }
}
